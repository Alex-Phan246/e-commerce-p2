{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://your-backend-url.vercel.app/api/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "https://your-backend-url.vercel.app/images/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "https://your-backend-url.vercel.app/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}