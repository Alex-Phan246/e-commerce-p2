{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/images/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/api/index.js"
    }
  ]
}